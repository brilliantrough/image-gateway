HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
UPSTREAM_REQUEST_TIMEOUT_MS=1800000

# Normal multi-upstream mode. Copy config/upstreams.example.json to this path,
# then edit the copy with your own upstream providers and API keys.
UPSTREAM_CONFIG_PATH=config/upstreams.json

# Admin auth for Config Center private routes and /?admin=1 UI.
# Leave unset only for local prototyping. In deployment, set at least
# ADMIN_PASSWORD + ADMIN_SESSION_SECRET, and optionally ADMIN_API_TOKEN.
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change_me
# ADMIN_SESSION_SECRET=replace_with_a_long_random_secret
# ADMIN_API_TOKEN=replace_with_a_long_random_token

# Legacy single OpenAI mode only. Leave these unset when using UPSTREAM_CONFIG_PATH.
# OPENAI_API_KEY=replace-with-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
