      "channelId": "aihubmix-openai",
      "modelKind": "image-generation",
      "enabled": true,
      "description": "Example AIHubMix OpenAI-compatible GPT Image route."
    },
    {
      "id": "aihubmix-gemini-31-flash-image",
      "displayName": "gemini-3.1-flash-image-preview",
